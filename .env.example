# ============================================================
# Great Marketing AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# All four variables are required for full lead-form functionality.
# ============================================================

# Resend API key — sends lead-form email notifications
# Sign up + create a key: https://resend.com/api-keys
# IMPORTANT: verify greatmarketing.ai as a sending domain in Resend first
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Recipient email for lead-form submissions
LEAD_NOTIFICATION_EMAIL=rafael@greatmarketing.ai

# Slack incoming webhook — posts lead alerts to the configured channel
# Create one: https://api.slack.com/messaging/webhooks
SLACK_LEAD_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Public site URL — used in canonical tags, sitemap, and JSON-LD schema
# Staging:    https://new.greatmarketing.ai
# Production: https://greatmarketing.ai
NEXT_PUBLIC_SITE_URL=https://new.greatmarketing.ai
